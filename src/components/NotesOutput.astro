---
---
<div id="notes-output-container" class="notes-output-container card">
  <!-- Workspace Header Toolbar -->
  <div class="workspace-header">
    <div class="workspace-tabs">
      <button class="tab-btn active" data-tab="detailed">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
        </svg>
        Detailed Notes
      </button>
      <button class="tab-btn" data-tab="summary">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <line x1="21" y1="9" x2="3" y2="9"></line>
          <line x1="21" y1="15" x2="3" y2="15"></line>
          <line x1="12" y1="3" x2="12" y2="21"></line>
        </svg>
        Quick Summary
      </button>
      <button class="tab-btn" data-tab="flashcards">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
        </svg>
        Flashcards
      </button>
      <button class="tab-btn" data-tab="mindmap">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <circle cx="12" cy="12" r="3"></circle>
          <line x1="18" y1="3" x2="12" y2="9"></line>
          <line x1="12" y1="15" x2="18" y2="21"></line>
        </svg>
        Mind Map
      </button>
    </div>

    <!-- Text Scale & Print Actions -->
    <div class="workspace-actions">
      <button id="font-decrease" class="icon-btn btn-secondary" title="Decrease font size">A-</button>
      <button id="font-increase" class="icon-btn btn-secondary" title="Increase font size">A+</button>
      <button id="print-layout-btn" class="icon-btn btn-secondary" title="Print Notes">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <polyline points="6 9 6 2 18 2 18 9"></polyline>
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
          <rect x="6" y="14" width="12" height="8"></rect>
        </svg>
      </button>
    </div>
  </div>

  <!-- Viewer Canvas -->
  <div id="viewer-canvas" class="viewer-canvas text-scale-medium">
    
    <!-- Detailed & Summary Views (Markdown) -->
    <div id="markdown-view" class="tab-content active markdown-body">
      <!-- Generated content goes here -->
    </div>

    <!-- Flashcards View -->
    <div id="flashcards-view" class="tab-content">
      <div class="flashcards-layout">
        <!-- 3D Card -->
        <div id="flashcard" class="flashcard-container">
          <div class="flashcard-inner">
            <div class="flashcard-front">
              <span class="card-side-label">QUESTION</span>
              <p id="card-question-text" class="card-main-text">Loading flashcard questions...</p>
            </div>
            <div class="flashcard-back">
              <span class="card-side-label">ANSWER</span>
              <p id="card-answer-text" class="card-main-text">Loading flashcard answers...</p>
            </div>
          </div>
        </div>

        <p class="flip-tip">💡 Click on the card to flip</p>

        <!-- Tracker & Control Bar -->
        <div class="flashcard-controls-container">
          <div class="flashcard-stats">
            <span id="flashcard-index">Card 1 of 12</span>
            <span id="flashcard-score">Score: 0 Got It</span>
          </div>
          
          <div class="progress-bar-bg" style="height: 4px; margin-bottom: var(--spacing-md);">
            <div id="flashcard-progress-bar" class="progress-bar-fill" style="width: 8%;"></div>
          </div>

          <div class="flashcard-actions-row">
            <button id="card-prev" class="btn btn-secondary">
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
              Prev
            </button>
            
            <div class="review-status-buttons">
              <button id="card-review" class="btn btn-secondary status-review" title="Mark for review">Review Again</button>
              <button id="card-gotit" class="btn btn-primary status-gotit" title="Mark as learned">Got it! ✓</button>
            </div>

            <button id="card-next" class="btn btn-secondary">
              Next
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Mind Map View -->
    <div id="mindmap-view" class="tab-content">
      <div class="mindmap-layout">
        <div class="mindmap-actions-row">
          <button id="mindmap-expand-all" class="btn btn-secondary btn-sm">Expand All</button>
          <button id="mindmap-collapse-all" class="btn btn-secondary btn-sm">Collapse All</button>
        </div>
        <div id="mindmap-tree-container" class="mindmap-tree">
          <!-- Dynamically generated list nodes -->
        </div>
      </div>
    </div>

  </div>

  <!-- Bottom Drawer Actions -->
  <div class="workspace-footer no-print">
    <div class="video-reference-info">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="var(--color-accent-red)" style="margin-right: 4px;">
        <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.108C19.524 3.545 12 3.545 12 3.545s-7.525 0-9.388.51a3.002 3.002 0 0 0-2.11 2.108C0 8.029 0 12 0 12s0 3.971.502 5.837a3.003 3.003 0 0 0 2.11 2.108c1.863.51 9.388.51 9.388.51s7.524 0 9.388-.51a3.002 3.002 0 0 0 2.11-2.108C24 15.971 24 12 24 12s0-3.971-.502-5.837z" />
        <path d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z" fill="white" />
      </svg>
      <a id="video-source-link" href="#" target="_blank" rel="noopener noreferrer" class="footer-link">Watch Original Video</a>
    </div>

    <div class="export-actions">
      <button id="export-copy" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        Copy Markdown
      </button>

      <button id="export-txt" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Download TXT
      </button>

      <button id="export-pdf" class="btn btn-primary">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
        </svg>
        Save PDF
      </button>

      <button id="export-share" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
          <circle cx="18" cy="5" r="3"></circle>
          <circle cx="6" cy="12" r="3"></circle>
          <circle cx="18" cy="19" r="3"></circle>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
        </svg>
        Share Note
      </button>
    </div>
  </div>
</div>

<!-- Slide up Toast Success Notification -->
<div id="toast" class="toast no-print">
  <svg viewBox="0 0 24 24" width="18" height="18" stroke="var(--color-accent-green)" stroke-width="2.5" fill="none">
    <polyline points="20 6 9 17 4 12"></polyline>
  </svg>
  <span id="toast-message">Notes copied to clipboard!</span>
</div>

<style>
  .notes-output-container {
    display: none; /* Shown dynamically on note completion */
    flex-direction: column;
    margin-top: var(--spacing-3xl);
    padding: 0;
    overflow: hidden;
  }

  .notes-output-container.active {
    display: flex;
  }

  /* Workspace Header */
  .workspace-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-hairline);
    padding: var(--spacing-md) var(--spacing-2xl);
    background-color: var(--color-canvas);
  }

  .workspace-tabs {
    display: flex;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: 1px solid transparent;
    padding: 8px 16px;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--color-body);
    border-radius: var(--rounded-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .tab-btn:hover {
    color: var(--color-ink);
    background-color: rgba(8, 8, 8, 0.02);
  }

  html[data-theme="dark"] .tab-btn:hover {
    background-color: rgba(255, 255, 255, 0.04);
  }

  .tab-btn.active {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
  }

  .workspace-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
  }

  /* Viewer Canvas Content Area */
  .viewer-canvas {
    padding: var(--spacing-3xl) var(--spacing-3xl);
    max-height: 700px;
    overflow-y: auto;
    background-color: var(--color-canvas);
    transition: font-size var(--transition-fast);
  }

  .text-scale-small { font-size: 13.8px !important; }
  .text-scale-medium { font-size: 15.5px !important; }
  .text-scale-large { font-size: 17.5px !important; }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Interactive Flashcards View Styling */
  .flashcards-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
    padding: var(--spacing-md) 0;
  }

  .card-side-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--color-mute);
    margin-bottom: var(--spacing-lg);
  }

  .card-main-text {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.5;
    text-align: center;
    max-width: 90%;
  }

  .flip-tip {
    font-size: 12.8px;
    color: var(--color-mute);
  }

  .flashcard-controls-container {
    width: 100%;
    max-width: 500px;
    margin-top: var(--spacing-sm);
  }

  .flashcard-stats {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-body);
    margin-bottom: var(--spacing-xs);
  }

  .flashcard-actions-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .review-status-buttons {
    display: flex;
    gap: var(--spacing-sm);
  }

  .status-review {
    border-color: rgba(238, 29, 54, 0.4);
    color: var(--color-accent-red);
  }

  .status-review:hover {
    background-color: rgba(238, 29, 54, 0.05);
    border-color: var(--color-accent-red);
  }

  .status-gotit {
    background-color: var(--color-accent-green);
    color: #080808;
    border-color: var(--color-accent-green);
  }

  .status-gotit:hover {
    opacity: 0.9;
  }

  /* Mindmap styles */
  .mindmap-layout {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .mindmap-actions-row {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: flex-end;
  }

  .btn-sm {
    padding: 6px 12px;
    font-size: 12px;
  }

  .mindmap-node-toggle {
    margin-right: 6px;
    cursor: pointer;
    font-weight: 700;
    user-select: none;
    color: var(--color-mute);
  }

  /* Workspace Footer Actions */
  .workspace-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-hairline);
    padding: var(--spacing-lg) var(--spacing-2xl);
    background-color: var(--color-canvas);
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .video-reference-info {
    display: flex;
    align-items: center;
  }

  .video-reference-info .footer-link {
    font-weight: 500;
    color: var(--color-accent-blue-deep);
    font-size: 14px;
    text-decoration: underline;
  }

  .export-actions {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  @media (max-width: 767px) {
    .workspace-header {
      padding: var(--spacing-md) var(--spacing-lg);
    }

    .viewer-canvas {
      padding: var(--spacing-xl) var(--spacing-lg);
    }

    .workspace-footer {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--spacing-lg) var(--spacing-lg);
    }

    .export-actions {
      width: 100%;
      justify-content: stretch;
    }

    .export-actions .btn {
      flex: 1 1 40%;
    }
  }
</style>

<script>
  import { marked } from 'marked';
  import confetti from 'canvas-confetti';

  // Global variables holding parsed outputs
  let notesDataRaw = {
    detailed: '',
    summary: '',
    flashcards: [] as Array<{q: string, a: string, score?: string}>,
    mindmap: [] as Array<any>,
    imagePrompt: '',
    videoId: ''
  };

  // State
  let currentActiveTab = 'detailed';
  let textScale = 'medium'; // small, medium, large
  let activeCardIndex = 0;
  let flashcardScoreVal = 0;

  // Cache elements
  const notesOutputContainer = document.getElementById('notes-output-container');
  const markdownView = document.getElementById('markdown-view');
  const flashcardsView = document.getElementById('flashcards-view');
  const mindmapView = document.getElementById('mindmap-view');

  const tabButtons = document.querySelectorAll('.tab-btn');
  const fontDecrease = document.getElementById('font-decrease');
  const fontIncrease = document.getElementById('font-increase');
  const printLayoutBtn = document.getElementById('print-layout-btn');
  
  const videoSourceLink = document.getElementById('video-source-link') as HTMLAnchorElement;

  const exportCopy = document.getElementById('export-copy');
  const exportTxt = document.getElementById('export-txt');
  const exportPdf = document.getElementById('export-pdf');
  const exportShare = document.getElementById('export-share');

  const toast = document.getElementById('toast');
  const toastMessage = document.getElementById('toast-message');

  // Load event handlers
  window.addEventListener('notes-generated', (e: any) => {
    const { notes, videoId, noteStyle, url } = e.detail;

    // Set video source URL
    if (videoSourceLink) {
      videoSourceLink.href = url || `https://www.youtube.com/watch?v=${videoId}`;
    }

    // Process raw output
    processNotesPayload(notes, noteStyle, videoId);
    
    // Activate and scroll into view
    if (notesOutputContainer) {
      notesOutputContainer.classList.add('active');
      notesOutputContainer.scrollIntoView({ behavior: 'smooth' });
    }

    // Display confettis on generation success!
    const end = Date.now() + 1000;
    const interval = setInterval(function() {
      if (Date.now() > end) {
        return clearInterval(interval);
      }
      confetti({
        startVelocity: 30,
        spread: 360,
        ticks: 60,
        origin: { x: Math.random(), y: Math.random() - 0.2 }
      });
    }, 200);
  });

  // Listeners for Tabs
  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      tabButtons.forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      
      const tabName = btn.getAttribute('data-tab') || 'detailed';
      currentActiveTab = tabName;
      
      // Hide all content areas
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      
      if (tabName === 'detailed' || tabName === 'summary') {
        if (markdownView) {
          markdownView.classList.add('active');
          const markdownText = tabName === 'detailed' ? notesDataRaw.detailed : notesDataRaw.summary;
          
          const imgHtml = notesDataRaw.imagePrompt 
            ? `<div class="notes-infographic-container no-print" style="margin-bottom: 24px; border-radius: 8px; overflow: hidden; border: 1px solid var(--color-hairline); box-shadow: var(--shadow-sm);">
                 <img src="https://image.pollinations.ai/prompt/${encodeURIComponent(notesDataRaw.imagePrompt)}?width=1024&height=576&nologo=true&seed=${notesDataRaw.videoId}" alt="AI Infographic" style="width: 100%; height: auto; display: block;" />
               </div>`
            : '';
            
          markdownView.innerHTML = imgHtml + (marked.parse(markdownText) as string);
        }
      } else if (tabName === 'flashcards') {
        if (flashcardsView) {
          flashcardsView.classList.add('active');
          renderFlashcard();
        }
      } else if (tabName === 'mindmap') {
        if (mindmapView) {
          mindmapView.classList.add('active');
          renderMindMap();
        }
      }
    });
  });

  // Client-side markdown fallback parser
  function parseMarkdownClient(text: string) {
    const sections = {
      detailed: '',
      summary: '',
      flashcards: [] as Array<{q: string, a: string}>,
      mindmap: [] as Array<{level: number, text: string}>,
      imagePrompt: 'Flat design vector infographic showing central study concepts'
    };

    const lines = text.split('\n');
    let currentSection = 'detailed';
    let detailedLines: string[] = [];
    let summaryLines: string[] = [];
    let flashcardText = '';
    let mindmapText = '';

    lines.forEach(line => {
      const trimmed = line.trim();
      if (trimmed.startsWith('#')) {
        const heading = trimmed.toLowerCase();
        if (heading.includes('summary') || heading.includes('tldr') || heading.includes('tl;dr')) {
          currentSection = 'summary';
        } else if (heading.includes('flashcard') || heading.includes('card')) {
          currentSection = 'flashcards';
        } else if (heading.includes('mindmap') || heading.includes('mind map') || heading.includes('concept map')) {
          currentSection = 'mindmap';
        } else if (heading.includes('image') || heading.includes('prompt')) {
          currentSection = 'imagePrompt';
        } else {
          currentSection = 'detailed';
          detailedLines.push(line);
        }
      } else {
        if (currentSection === 'detailed') {
          detailedLines.push(line);
        } else if (currentSection === 'summary') {
          summaryLines.push(line);
        } else if (currentSection === 'flashcards') {
          flashcardText += line + '\n';
        } else if (currentSection === 'mindmap') {
          mindmapText += line + '\n';
        } else if (currentSection === 'imagePrompt') {
          sections.imagePrompt += ' ' + trimmed;
        }
      }
    });

    sections.detailed = detailedLines.join('\n').trim();
    sections.summary = summaryLines.join('\n').trim();

    // Parse cards
    const cardLines = (flashcardText || sections.detailed).split('\n');
    let currentQ = '';
    let currentA = '';
    cardLines.forEach(line => {
      const trimmed = line.trim();
      if (trimmed.toLowerCase().startsWith('q:') || trimmed.toLowerCase().startsWith('question:')) {
        if (currentQ && currentA) {
          sections.flashcards.push({ q: currentQ, a: currentA });
          currentQ = '';
          currentA = '';
        }
        currentQ = trimmed.replace(/^[qQ]:\s*/i, '').replace(/^question:\s*/i, '').trim();
      } else if (trimmed.toLowerCase().startsWith('a:') || trimmed.toLowerCase().startsWith('answer:')) {
        currentA = trimmed.replace(/^[aA]:\s*/i, '').replace(/^answer:\s*/i, '').trim();
      } else if (currentQ && !currentA) {
        currentQ += ' ' + trimmed;
      } else if (currentQ && currentA) {
        currentA += ' ' + trimmed;
      }
    });
    if (currentQ && currentA) {
      sections.flashcards.push({ q: currentQ, a: currentA });
    }

    // Parse mindmap
    const mmLines = (mindmapText || sections.detailed).split('\n');
    mmLines.forEach(line => {
      const trimmed = line.trim();
      if (trimmed.startsWith('-') || trimmed.startsWith('*') || /^\d+\./.test(trimmed)) {
        const leadingSpaces = line.length - line.trimStart().length;
        const level = Math.min(4, Math.max(1, Math.floor(leadingSpaces / 2) + 1));
        const textVal = trimmed.replace(/^[-*\d.]+\s*/, '').trim();
        if (textVal) {
          sections.mindmap.push({ level, text: textVal });
        }
      }
    });

    // Fallbacks if sections were not populated
    if (sections.flashcards.length === 0) {
      const bLines = sections.detailed.split('\n').filter(l => l.trim().startsWith('-') && l.includes(':'));
      bLines.slice(0, 8).forEach(bullet => {
        const parts = bullet.trim().substring(1).split(':');
        if (parts.length >= 2) {
          sections.flashcards.push({
            q: `Explain the concept of "${parts[0].trim().replace(/\*\*/g, '')}"`,
            a: parts.slice(1).join(':').trim()
          });
        }
      });
    }

    if (sections.mindmap.length === 0) {
      sections.detailed.split('\n').forEach(line => {
        const trimmed = line.trim();
        if (trimmed.startsWith('#')) {
          const hashCount = (trimmed.match(/#/g) || []).length;
          const level = Math.min(4, hashCount);
          const textVal = trimmed.replace(/^#+\s*/, '').trim();
          if (textVal) {
            sections.mindmap.push({ level, text: textVal });
          }
        }
      });
    }

    if (sections.flashcards.length === 0) {
      sections.flashcards = [{ q: "What is the primary topic discussed in the video?", a: "Please refer to the Detailed Notes tab for a full conceptual breakdown." }];
    }
    if (sections.mindmap.length === 0) {
      sections.mindmap = [{ level: 1, text: "Main Topic" }, { level: 2, text: "Refer to Detailed Notes for sections" }];
    }
    if (!sections.summary) {
      sections.summary = sections.detailed.substring(0, 400) + '...';
    }

    return sections;
  }

  // Parser: splits raw notes into styles
  function processNotesPayload(notes: any, activeStyle: string, videoId: string) {
    notesDataRaw.videoId = videoId;
    
    let parsedNotes = notes;
    if (typeof notes === 'string') {
      try {
        parsedNotes = JSON.parse(notes);
      } catch (e) {
        parsedNotes = parseMarkdownClient(notes);
      }
    }

    notesDataRaw.detailed = parsedNotes.detailed || '';
    notesDataRaw.summary = parsedNotes.summary || '';
    notesDataRaw.flashcards = parsedNotes.flashcards || [];
    notesDataRaw.imagePrompt = parsedNotes.imagePrompt || '';
    notesDataRaw.mindmap = parsedNotes.mindmap || [];

    activeCardIndex = 0;
    flashcardScoreVal = 0;
    updateScoreDisplay();

    // Auto trigger tab update
    const activeBtn = document.querySelector(`.tab-btn[data-tab="${activeStyle}"]`) as HTMLButtonElement;
    if (activeBtn) {
      activeBtn.click();
    } else {
      const defaultBtn = document.querySelector('.tab-btn[data-tab="detailed"]') as HTMLButtonElement;
      if (defaultBtn) defaultBtn.click();
    }
  }

  // 3D Card Flipping Logic
  const flashcardElement = document.getElementById('flashcard');
  if (flashcardElement) {
    flashcardElement.addEventListener('click', () => {
      flashcardElement.classList.toggle('is-flipped');
    });
  }

  // Flashcard Navigation
  function renderFlashcard() {
    const card = notesDataRaw.flashcards[activeCardIndex];
    if (!card) return;

    // Reset card flip
    if (flashcardElement) flashcardElement.classList.remove('is-flipped');

    // Load text
    const qText = document.getElementById('card-question-text');
    const aText = document.getElementById('card-answer-text');
    if (qText) qText.innerHTML = marked.parseInline(card.q);
    if (aText) aText.innerHTML = marked.parseInline(card.a);

    // Update index display
    const idxText = document.getElementById('flashcard-index');
    if (idxText) idxText.textContent = `Card ${activeCardIndex + 1} of ${notesDataRaw.flashcards.length}`;

    // Progress bar
    const progressFill = document.getElementById('flashcard-progress-bar');
    if (progressFill) {
      const pct = ((activeCardIndex + 1) / notesDataRaw.flashcards.length) * 100;
      progressFill.style.width = `${pct}%`;
    }
  }

  function updateScoreDisplay() {
    const scoreText = document.getElementById('flashcard-score');
    if (scoreText) scoreText.textContent = `Score: ${flashcardScoreVal} Got It`;
  }

  // Prev / Next button listeners
  const cardPrevBtn = document.getElementById('card-prev');
  const cardNextBtn = document.getElementById('card-next');
  const cardGotItBtn = document.getElementById('card-gotit');
  const cardReviewBtn = document.getElementById('card-review');

  if (cardPrevBtn) {
    cardPrevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (activeCardIndex > 0) {
        activeCardIndex--;
        renderFlashcard();
      }
    });
  }

  if (cardNextBtn) {
    cardNextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (activeCardIndex < notesDataRaw.flashcards.length - 1) {
        activeCardIndex++;
        renderFlashcard();
      }
    });
  }

  if (cardGotItBtn) {
    cardGotItBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      // Only increment score if not already marked gotit
      const currentCard = notesDataRaw.flashcards[activeCardIndex];
      if (currentCard && !currentCard.score) {
        currentCard.score = 'gotit';
        flashcardScoreVal++;
        updateScoreDisplay();
      }
      
      // Auto advance
      if (activeCardIndex < notesDataRaw.flashcards.length - 1) {
        activeCardIndex++;
        setTimeout(renderFlashcard, 200);
      } else {
        showToast("Great job! You reviewed all cards.");
        confetti({ particleCount: 50, angle: 60, spread: 55, origin: { x: 0 } });
        confetti({ particleCount: 50, angle: 120, spread: 55, origin: { x: 1 } });
      }
    });
  }

  if (cardReviewBtn) {
    cardReviewBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const currentCard = notesDataRaw.flashcards[activeCardIndex];
      if (currentCard && currentCard.score === 'gotit') {
        currentCard.score = undefined;
        if (flashcardScoreVal > 0) flashcardScoreVal--;
        updateScoreDisplay();
      }

      // Auto advance
      if (activeCardIndex < notesDataRaw.flashcards.length - 1) {
        activeCardIndex++;
        setTimeout(renderFlashcard, 200);
      }
    });
  }

  // Mindmap Visual Renderer
  function renderMindMap() {
    const container = document.getElementById('mindmap-tree-container');
    if (!container) return;

    container.innerHTML = '';
    const tree = notesDataRaw.mindmap;

    let html = '<ul>';
    let currentLevel = 0;

    tree.forEach((node, i) => {
      const nodeClass = node.level === 1 ? 'mindmap-node mindmap-node-root' : 'mindmap-node';
      const toggleSpan = node.level < 4 ? `<span class="mindmap-node-toggle">▼</span>` : '';

      if (node.level > currentLevel) {
        if (currentLevel > 0) html += '<ul>';
      } else if (node.level < currentLevel) {
        html += '</li></ul>'.repeat(currentLevel - node.level) + '</li>';
      } else {
        if (i > 0) html += '</li>';
      }

      html += `<li class="mindmap-item" data-level="${node.level}">
        <div class="${nodeClass}">
          ${toggleSpan}
          <span>${marked.parseInline(node.text)}</span>
        </div>`;

      currentLevel = node.level;
    });

    html += '</li></ul>'.repeat(currentLevel) + '</ul>';
    container.innerHTML = html;

    // Attach collapsible events to mindmap nodes
    const toggles = container.querySelectorAll('.mindmap-node-toggle');
    toggles.forEach(toggle => {
      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const node = toggle.closest('.mindmap-node');
        const parentLi = toggle.closest('li');
        const subList = parentLi ? parentLi.querySelector('ul') : null;

        if (subList) {
          if (subList.style.display === 'none') {
            subList.style.display = 'block';
            toggle.textContent = '▼';
          } else {
            subList.style.display = 'none';
            toggle.textContent = '▶';
          }
        }
      });
    });
  }

  // Expand / Collapse All Mindmap Nodes
  const expandAllBtn = document.getElementById('mindmap-expand-all');
  const collapseAllBtn = document.getElementById('mindmap-collapse-all');

  if (expandAllBtn) {
    expandAllBtn.addEventListener('click', () => {
      const lists = document.querySelectorAll('.mindmap-tree ul');
      lists.forEach(l => { (l as HTMLUListElement).style.display = 'block'; });
      const toggles = document.querySelectorAll('.mindmap-node-toggle');
      toggles.forEach(t => { t.textContent = '▼'; });
    });
  }

  if (collapseAllBtn) {
    collapseAllBtn.addEventListener('click', () => {
      const lists = document.querySelectorAll('.mindmap-tree ul ul');
      lists.forEach(l => { (l as HTMLUListElement).style.display = 'none'; });
      const toggles = document.querySelectorAll('.mindmap-node-toggle');
      toggles.forEach(t => { t.textContent = '▶'; });
    });
  }

  // Toast Functionality
  function showToast(message: string) {
    if (toast && toastMessage) {
      toastMessage.textContent = message;
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
      }, 2500);
    }
  }

  // Text Scaling Settings
  const viewerCanvas = document.getElementById('viewer-canvas');
  if (fontDecrease && fontIncrease && viewerCanvas) {
    fontDecrease.addEventListener('click', () => {
      if (textScale === 'large') {
        textScale = 'medium';
        viewerCanvas.className = 'viewer-canvas text-scale-medium';
      } else if (textScale === 'medium') {
        textScale = 'small';
        viewerCanvas.className = 'viewer-canvas text-scale-small';
      }
    });

    fontIncrease.addEventListener('click', () => {
      if (textScale === 'small') {
        textScale = 'medium';
        viewerCanvas.className = 'viewer-canvas text-scale-medium';
      } else if (textScale === 'medium') {
        textScale = 'large';
        viewerCanvas.className = 'viewer-canvas text-scale-large';
      }
    });
  }

  // Dynamic html2pdf rendering with premium aesthetics and pagebreak protection
  function generateFullPDF() {
    // @ts-ignore
    if (typeof html2pdf === 'undefined') {
      showToast("Loading PDF generator, please wait...");
      const script = document.createElement('script');
      script.src = "https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js";
      script.onload = () => {
        generateFullPDF();
      };
      document.head.appendChild(script);
      return;
