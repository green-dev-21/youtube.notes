---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — YouTube to Notes AI"
  description="Sorry, the page you are looking for does not exist. Go back to our main note generator."
  noindex={true}
>
  <section class="section" style="flex: 1; display: flex; align-items: center; justify-content: center; min-height: 60vh;">
    <div class="container" style="text-align: center; max-width: 480px;">
      <span class="eyebrow" style="color: var(--color-accent-red);">ERROR 404</span>
      <h1 style="font-size: 56px; line-height: 1; margin-bottom: var(--spacing-md); color: var(--color-ink);">Page Not Found</h1>
      <p style="font-size: 16px; color: var(--color-body); margin-bottom: var(--spacing-xl); line-height: 1.5;">
        The link you followed might be broken, or the page may have been removed. Let's get you back to studying.
      </p>
      <a href="/" class="btn btn-primary btn-large" style="display: inline-flex; width: 100%;">
        Go to Notes Generator
      </a>
    </div>
  </section>
</BaseLayout>
