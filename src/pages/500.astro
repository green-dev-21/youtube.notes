---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Server Error — YouTube to Notes AI"
  description="An unexpected error occurred on our servers. Please try again."
  noindex={true}
>
  <section class="section" style="flex: 1; display: flex; align-items: center; justify-content: center; min-height: 60vh;">
    <div class="container" style="text-align: center; max-width: 480px;">
      <span class="eyebrow" style="color: var(--color-accent-red);">ERROR 500</span>
      <h1 style="font-size: 56px; line-height: 1; margin-bottom: var(--spacing-md); color: var(--color-ink);">Server Error</h1>
      <p style="font-size: 16px; color: var(--color-body); margin-bottom: var(--spacing-xl); line-height: 1.5;">
        An unexpected error occurred on our serverless edge node. This can happen during temporary database congestion or API limits.
      </p>
      <div style="display: flex; flex-direction: column; gap: var(--spacing-sm);">
        <a href="/" class="btn btn-primary btn-large" style="width: 100%;">
          Try Again
        </a>
        <a href="/contact" class="btn btn-secondary btn-large" style="width: 100%;">
          Contact Support
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
